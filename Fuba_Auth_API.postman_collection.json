{
	"info": {
		"_postman_id": "fuba-auth-api-collection",
		"name": "Fuba Authentication API",
		"description": "Complete authentication API for Fuba - Customer, Food Vendor, and Luxury Restaurant flows.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000/api",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "verification_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "test_email",
			"value": "test@example.com",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Customer Auth",
			"description": "Normal customer signup and authentication flow",
			"item": [
				{
					"name": "1. Initiate Email Verification",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.test('Verification initiated', function() {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData.success).to.be.true;",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/initiate-verification",
							"host": ["{{base_url}}"],
							"path": ["auth", "initiate-verification"]
						},
						"description": "Send a 4-digit OTP to the customer's email to start registration."
					},
					"response": []
				},
				{
					"name": "2. Verify Email OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('verification_token', jsonData.verification_token);",
									"    pm.test('Email verified', function() {",
									"        pm.expect(jsonData.success).to.be.true;",
									"        pm.expect(jsonData.verification_token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"otp\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/verify-email",
							"host": ["{{base_url}}"],
							"path": ["auth", "verify-email"]
						},
						"description": "Verify the 4-digit OTP sent to the customer's email."
					},
					"response": []
				},
				{
					"name": "3. Complete Registration",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('auth_token', jsonData.token);",
									"    pm.test('Registration completed', function() {",
									"        pm.expect(jsonData.success).to.be.true;",
									"        pm.expect(jsonData.token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"verification_token\": \"{{verification_token}}\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone_number\": \"08012345678\",\n    \"password\": \"SecurePass123!\",\n    \"role\": \"consumer\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "Complete customer registration with personal details after email verification."
					},
					"response": []
				},
				{
					"name": "Resend Verification Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{test_email}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/resend-verification-email",
							"host": ["{{base_url}}"],
							"path": ["auth", "resend-verification-email"]
						},
						"description": "Resend the verification OTP to the user's email."
					},
					"response": []
				}
			]
		},
