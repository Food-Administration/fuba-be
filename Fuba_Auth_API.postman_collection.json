					},
					"response": []
				},
				{
					"name": "Change Password (Authenticated)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"currentPassword\": \"SecurePass123!\",\n    \"newPassword\": \"NewSecurePass456!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/change-password",
							"host": ["{{base_url}}"],
							"path": ["auth", "change-password"]
						},
						"description": "Change password while authenticated. Requires current password."
					},
					"response": []
				}
			]
		},
		{
			"name": "Food Vendor Auth",
			"description": "Food Vendor signup flow - area check, waitlist, verification, registration, NAFDAC seal",
			"item": [
				{
					"name": "1. Check Area Availability",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"state\": \"Lagos\",\n    \"brand_address\": \"123 Victoria Island, Lagos\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/check-area",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "check-area"]
						},
						"description": "Check if Fuba service is available in the vendor's area. Returns available: true/false."
					},
					"response": []
				},
				{
					"name": "2a. Join Waitlist (If Area Unavailable)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"vendor@example.com\",\n    \"phone_number\": \"08098765432\",\n    \"state\": \"Kano\",\n    \"brand_address\": \"45 Main Street, Kano\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/waitlist",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "waitlist"]
						},
						"description": "Join the waitlist to be notified when Fuba is available in the vendor's area."
					},
					"response": []
				},
				{
					"name": "2b. Initiate Vendor Verification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"vendor@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/initiate-verification",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "initiate-verification"]
						},
						"description": "Send a 4-digit OTP to the vendor's email to start registration."
					},
					"response": []
				},
				{
					"name": "3. Verify Vendor OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('verification_token', jsonData.verification_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"vendor@example.com\",\n    \"otp\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/verify",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "verify"]
						},
						"description": "Verify the 4-digit OTP sent to the vendor's email."
					},
					"response": []
				},
				{
					"name": "4. Complete Vendor Registration",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('auth_token', jsonData.token);",
									"    pm.test('Vendor registration completed', function() {",
									"        pm.expect(jsonData.success).to.be.true;",
									"        pm.expect(jsonData.vendor_profile).to.be.an('object');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"verification_token\": \"{{verification_token}}\",\n    \"first_name\": \"Jane\",\n    \"last_name\": \"Chef\",\n    \"phone_number\": \"08098765432\",\n    \"password\": \"VendorPass123!\",\n    \"brand_name\": \"Jane's Kitchen\",\n    \"brand_description\": \"Authentic Nigerian meals prepared with love\",\n    \"state\": \"Lagos\",\n    \"brand_address\": \"123 Victoria Island, Lagos\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "register"]
						},
						"description": "Complete vendor registration with personal details, brand info. Brand image and cover image can be uploaded via user profile update later."
					},
					"response": []
				},
				{
					"name": "5. Request NAFDAC Seal (Authenticated)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"brand_name\": \"Jane's Kitchen\",\n    \"business_email\": \"jane@janeskitchen.com\",\n    \"brand_address\": \"123 Victoria Island, Lagos\",\n    \"brand_phone\": \"08098765432\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/nafdac-request",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "nafdac-request"]
						},
						"description": "Request NAFDAC seal. Initializes Paystack payment. Returns payment_url to redirect user for payment."
					},
					"response": []
				},
				{
					"name": "6. Verify NAFDAC Payment (Authenticated)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"payment_reference\": \"nafdac_userId_timestamp\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/nafdac-verify-payment",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "nafdac-verify-payment"]
						},
						"description": "Verify NAFDAC seal payment via Paystack after user completes payment."
					},
					"response": []
				},
				{
					"name": "7. Upload NAFDAC Seal (Authenticated)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "brand_name",
									"value": "Jane's Kitchen",
									"type": "text"
								},
								{
									"key": "brand_email",
									"value": "jane@janeskitchen.com",
									"type": "text"
								},
								{
									"key": "brand_address",
									"value": "123 Victoria Island, Lagos",
									"type": "text"
								},
								{
									"key": "nafdac_seal",
									"type": "file",
									"src": ""
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/auth/vendor/nafdac-upload",
							"host": ["{{base_url}}"],
							"path": ["auth", "vendor", "nafdac-upload"]
						},
						"description": "Upload NAFDAC seal document after payment verification. File field: nafdac_seal (PDF/image)."
					},
					"response": []
				}
			]
		},
